{
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/gateway-log-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Issuer": "MicroservicesSolution.Identity",
    "Audience": "MicroservicesSolution.Clients",
    "Key": "A_Very_Long_And_Secure_Secret_Key_For_Jwt_Generation_2026"
  },
  "ReverseProxy": {
    "Routes": {
      "identityRoute": {
        "ClusterId": "identityCluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/identity" }
        ]
      },
      "userSwaggerRoute": {
        "ClusterId": "userCluster",
        "Match": {
          "Path": "/api/user/swagger/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/user" }
        ]
      },
      "userRoute": {
        "ClusterId": "userCluster",
        "AuthorizationPolicy": "CitizenOnly",
        "Match": {
          "Path": "/api/user/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/user" }
        ]
      },
      "orderSwaggerRoute": {
        "ClusterId": "orderCluster",
        "Match": {
          "Path": "/api/order/swagger/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/order" }
        ]
      },
      "orderRoute": {
        "ClusterId": "orderCluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/order/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/order" }
        ]
      },
      "productSwaggerRoute": {
        "ClusterId": "productCluster",
        "Match": {
          "Path": "/api/product/swagger/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/product" }
        ]
      },
      "productRoute": {
        "ClusterId": "productCluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/product/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/product" }
        ]
      }
    },
    "Clusters": {
      "identityCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:49693"
          }
        }
      },
      "userCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:49694"
          }
        }
      },
      "orderCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:49692"
          }
        }
      },
      "productCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:49688"
          }
        }
      }
    }
  }
}
